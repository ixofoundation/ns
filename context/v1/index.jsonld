{
  "@context": {
    "@version": 1.1,

    "schema": "http://schema.org/",
    "xsd": "http://www.w3.org/2001/XMLSchema#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#",
    "owl": "http://www.w3.org/2002/07/owl#",
    "skos": "http://www.w3.org/2004/02/skos/core#",
    "prov": "http://www.w3.org/ns/prov#",
    "dcterms": "http://purl.org/dc/terms/",
    "foaf": "http://xmlns.com/foaf/0.1/",
    "did": "https://www.w3.org/ns/did#",
    "cred": "https://www.w3.org/2018/credentials#",
    "sec": "https://w3id.org/security#",
    "zcap": "https://w3id.org/zcap#",
    "dpv": "https://w3id.org/dpv#",
    "proj": "https://linked.data.gov.au/def/project#",
    "attribute": "https://w3id.org/ixo/attributes/v1/",
    "wgs84": "http://www.w3.org/2003/01/geo/wgs84_pos#",
    "fibo": "https://spec.edmcouncil.org/fibo/ontology/",

    "ixo": "https://w3id.org/ixo/vocab/v1#",
    "entityType": "https://w3id.org/ixo/protocol/entities/v1#",
    "claimType": "https://w3id.org/ixo/protocol/claims/v1#",
    "credType": "https://w3id.org/ixo/protocol/credentials/v1#",
    "oracleCap": "https://w3id.org/ixo/protocol/oracle-capabilities/v1#",
    "status": "https://w3id.org/ixo/protocol/entity-status/v1#",
    "stage": "https://w3id.org/ixo/protocol/entity-stage/v1#",
    "view": "https://w3id.org/ixo/protocol/entity-view/v1#",
    "paymentType": "https://w3id.org/ixo/protocol/payments/v1#",
    "paymentDenom": "https://w3id.org/ixo/protocol/payment-denominations/v1#",
    "stakeType": "https://w3id.org/ixo/protocol/stake-types/v1#",
    "slashCondition": "https://w3id.org/ixo/protocol/slashing-conditions/v1#",
    "nodeType": "https://w3id.org/ixo/protocol/node-types/v1#",
    "liquiditySource": "https://w3id.org/ixo/protocol/liquidity-sources/v1#",
    "agentRole": "https://w3id.org/ixo/protocol/agent-roles/v1#",
    "evalCode": "https://w3id.org/ixo/protocol/evaluation-codes/v1#",
    "country": "https://w3id.org/ixo/vocab/v1/countries#",
    "resourceType": "https://w3id.org/ixo/protocol/linked-resources/v1#",
    "rightType": "https://w3id.org/ixo/protocol/accorded-rights/v1#",
    "relType": "https://w3id.org/ixo/protocol/relationships/v1#",

    "id": { "@id": "@id", "@protected": true },
    "type": { "@id": "@type", "@protected": true },

    "controller": { "@id": "ixo:controller", "@type": "@id", "@container": "@set", "@protected": true },
    "verificationMethod": { "@id": "ixo:verificationMethod", "@type": "@id", "@container": "@set", "@protected": true },
    "authentication": { "@id": "ixo:authentication", "@type": "@id", "@container": "@set", "@protected": true },
    "assertionMethod": { "@id": "ixo:assertionMethod", "@type": "@id", "@container": "@set", "@protected": true },
    "keyAgreement": { "@id": "ixo:keyAgreement", "@type": "@id", "@container": "@set", "@protected": true },
    "capabilityInvocation": { "@id": "ixo:capabilityInvocation", "@type": "@id", "@container": "@set", "@protected": true },
    "capabilityDelegation": { "@id": "ixo:capabilityDelegation", "@type": "@id", "@container": "@set", "@protected": true },

    "service": { "@id": "ixo:service", "@type": "@id", "@container": "@set" },
    "linkedResource": { "@id": "ixo:linkedResource", "@container": "@set" },
    "linkedClaim": { "@id": "ixo:linkedClaim", "@container": "@set" },
    "linkedEntity": { "@id": "ixo:linkedEntity", "@container": "@set" },
    "accordedRight": { "@id": "ixo:accordedRight", "@container": "@set" },
    "account": { "@id": "ixo:account", "@container": "@set" },
    "settings": { "@id": "ixo:settings" },

    "name": "schema:name",
    "description": "schema:description",
    "image": { "@id": "schema:image", "@type": "@id" },

    "serviceEndpoint": { "@id": "ixo:serviceEndpoint" },
    "blockchainAccountID": "ixo:blockchainAccountID",
    "CosmosAccountAddress": "ixo:CosmosAccountAddress",
    "publicKeyBase58": "sec:publicKeyBase58",
    "publicKeyMultibase": "sec:publicKeyMultibase",
    "alsoKnownAs": { "@id": "ixo:alsoKnownAs", "@type": "@id" },
    "relayerNode": { "@id": "ixo:relayerNode", "@type": "@id" },
    "metadata": { "@id": "ixo:metadata" },
    "versionId": "ixo:versionId",
    "deactivated": "ixo:deactivated",
    "mediaType": "dcterms:format",
    "encrypted": "ixo:encrypted",
    "right": { "@id": "ixo:right" },

    "title": "dcterms:title",
    "value": "schema:value",
    "url": { "@id": "schema:url", "@type": "@id" },
    "logo": { "@id": "schema:logo", "@type": "@id" },
    "brand": "schema:brand",
    "location": "schema:location",
    "label": "rdfs:label",
    "orgName": "schema:legalName",
    "metrics": { "@id": "ixo:metrics" },
    "attributes": { "@id": "ixo:attributes" },
    "tokenName": "ixo:tokenName",
    "decimals": "ixo:decimals",
    "properties": { "@id": "ixo:properties" },
    "tags": "ixo:tags",
    "entityTags": "ixo:entityTags",
    "page": { "@id": "ixo:page" },
    "pages": { "@id": "ixo:pages" },
    "hasClaimType": { "@id": "ixo:claimType", "@type": "@id" },
    "relationship": { "@id": "ixo:relationship", "@type": "@id" },

    "claimId": "ixo:claimId",
    "projectDid": { "@id": "ixo:projectDid", "@type": "@id" },
    "agentDid": { "@id": "ixo:agentDid", "@type": "@id" },
    "evaluatorDid": { "@id": "ixo:evaluatorDid", "@type": "@id" },
    "sdgGoal": "ixo:sdgGoal",
    "sdgTarget": "ixo:sdgTarget",
    "outcomeIndicator": "ixo:outcomeIndicator",
    "impactVolume": "ixo:impactVolume",
    "impactUnit": "ixo:impactUnit",
    "evidenceType": "ixo:evidenceType",
    "serviceType": "ixo:serviceType",
    "beneficiaryId": "ixo:beneficiaryId",
    "oracleName": "ixo:oracleName",
    "requiredPermissions": "ixo:requiredPermissions",
    "granteeAddress": "ixo:granteeAddress",
    "granterAddress": "ixo:granterAddress",

    "wasGeneratedBy": { "@id": "prov:wasGeneratedBy", "@type": "@id" },
    "wasDerivedFrom": { "@id": "prov:wasDerivedFrom", "@type": "@id" },
    "wasAttributedTo": { "@id": "prov:wasAttributedTo", "@type": "@id" },
    "wasAssociatedWith": { "@id": "prov:wasAssociatedWith", "@type": "@id" },
    "generatedAtTime": { "@id": "prov:generatedAtTime", "@type": "xsd:dateTime" }
  }
}
