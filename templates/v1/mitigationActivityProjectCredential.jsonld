{
  "@context": ["https://www.w3.org/2018/credentials/v1", "https://w3id.org/ixo/context/v1"],
  "id": "did:ixo:entity:REPLACE-CREDENTIAL-ID#mitigationActivityProject",
  "type": ["VerifiableCredential", "ixo:Credential"],
  "issuer": "did:ixo:entity:REPLACE-ISSUER-ID",
  "issuanceDate": "<<<ISO 8601 timestamp>>>",
  "credentialSubject": {
    "id": "did:ixo:entity:REPLACE-PROJECT-ID",
    "type": "ixo:Project",
    "name": "<<<Mitigation activity / project name>>>",
    "description": "<<<What the mitigation activity does>>>",
    "activityType": "<<<e.g. clean cooking, afforestation, renewable energy>>>",
    "methodology": "<<<Methodology reference, e.g. CDM AMS-II.G>>>",
    "country": "<<<ISO 3166-1 alpha-2 country code>>>",
    "creditingPeriod": { "start": "<<<ISO 8601 date>>>", "end": "<<<ISO 8601 date>>>" },
    "estimatedReductions": { "value": "<<<estimated reductions>>>", "unit": "tCO2e" }
  }
}
