{
  "@context": ["https://www.w3.org/2018/credentials/v1", "https://w3id.org/ixo/context/v1"],
  "id": "did:ixo:entity:REPLACE-CREDENTIAL-ID#voucher",
  "type": ["VerifiableCredential", "ixo:Credential"],
  "issuer": "did:ixo:entity:REPLACE-ISSUER-ID",
  "issuanceDate": "<<<ISO 8601 timestamp>>>",
  "credentialSubject": {
    "id": "did:ixo:entity:REPLACE-VOUCHER-ID",
    "type": "ixo:Asset",
    "name": "<<<Voucher name>>>",
    "description": "<<<What the voucher can be redeemed for>>>",
    "voucherType": "<<<e.g. fuel, service, goods>>>",
    "faceValue": { "value": "<<<amount>>>", "currency": "<<<ISO 4217 currency code>>>" },
    "redeemableFor": "<<<goods or services description>>>",
    "validUntil": "<<<ISO 8601 date>>>"
  }
}
