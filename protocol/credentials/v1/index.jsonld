      },
      "skos:prefLabel": {
        "@value": "Verifiable Credential",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "A digital credential that can be cryptographically verified and contains claims about a subject.",
        "@language": "en"
      },
      "skos:notation": "verifiableCredential",
      "skos:topConceptOf": {
        "@id": "https://w3id.org/ixo/protocol/credentials/v1"
      }
    },
