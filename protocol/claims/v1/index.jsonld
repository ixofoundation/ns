        "@value": "A claim documenting measured results or impacts of specific actions or initiatives.",
        "@language": "en"
      },
      "skos:notation": "outcome",
      "skos:topConceptOf": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
