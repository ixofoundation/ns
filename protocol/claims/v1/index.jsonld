      },
      "skos:prefLabel": {
        "@value": "Dispute",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "A claim documenting formal disagreements and their resolution processes.",
        "@language": "en"
      },
      "skos:notation": "dispute",
      "skos:topConceptOf": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      }
    },
    {
      "@id": "#identity",
