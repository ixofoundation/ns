      "skos:inScheme": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      },
      "skos:prefLabel": {
        "@value": "Identity",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "A claim verifying the authentic identity attributes of an individual, organization, or domain.",
        "@language": "en"
      },
      "skos:notation": "identity",
      "skos:topConceptOf": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      }
    },
    {
