      "skos:prefLabel": {
        "@value": "Ownership",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "A claim validating the rightful possession or control of assets, resources, or rights.",
        "@language": "en"
      },
      "skos:notation": "ownership",
