    {
      "@id": "#accreditation",
      "@type": "skos:Concept",
      "skos:inScheme": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      },
      "skos:prefLabel": {
        "@value": "Accreditation",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "A claim verifying the official recognition, authorization, or certification status of a domain or process.",
        "@language": "en"
      },
      "skos:notation": "accreditation",
      "skos:topConceptOf": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      }
    },
    {
      "@id": "#compliance",
      "@type": "skos:Concept",
      "skos:inScheme": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      },
      "skos:prefLabel": {
        "@value": "Compliance",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "A claim attesting to adherence to specific regulatory, legal, or protocol requirements.",
        "@language": "en"
      },
      "skos:notation": "compliance",
      "skos:topConceptOf": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      }
    },
    {
      "@id": "#contribution",
      "@type": "skos:Concept",
      "skos:inScheme": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      },
      "skos:prefLabel": {
        "@value": "Contribution",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "A claim documenting verified contributions to projects, initiatives, or common objectives.",
        "@language": "en"
      },
      "skos:notation": "contribution",
      "skos:topConceptOf": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      }
    },
    {
      "@id": "#credential",
      "@type": "skos:Concept",
      "skos:inScheme": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      },
      "skos:prefLabel": {
        "@value": "Credential",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "A claim establishing the authenticity and validity of qualifications, permissions, or rights.",
        "@language": "en"
      },
      "skos:notation": "credential",
      "skos:topConceptOf": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      }
    },
    {
      "@id": "#credentialAudit",
