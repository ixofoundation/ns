      "skos:inScheme": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      },
      "skos:prefLabel": {
        "@value": "Credential Audit",
        "@language": "en"
      },
      "skos:definition": {
        "@value": "A claim documenting the systematic examination and verification of credential issuance and management.",
        "@language": "en"
      },
      "skos:notation": "credentialAudit",
      "skos:topConceptOf": {
        "@id": "https://w3id.org/ixo/protocol/claims/v1"
      }
    },
    {
      "@id": "#dispute",
