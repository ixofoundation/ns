{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/ixo/schema/v1/page",
  "title": "IXO Entity Page",
  "description": "Document-shape schema for an entity Page linked resource (the IXO wrapper; embedded rich-text/editor content is validated by its own tooling). Graph-shape rules live in shapes/v1/PageShape.jsonld.",
  "type": "object",
  "required": ["@context", "type"],
  "properties": {
    "@context": { "oneOf": [{ "type": "string" }, { "type": "array", "minItems": 1 }, { "type": "object" }] },
    "id": { "type": "string" },
    "type": { "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }] },
    "page": { "type": ["object", "array"] },
    "pages": { "type": "array" }
  },
  "anyOf": [{ "required": ["page"] }, { "required": ["pages"] }]
}
