{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/ixo/schema/v1/credential",
  "title": "IXO Verifiable Credential",
  "description": "Document-shape schema for a verifiable credential issued on the IXO Spatial Web. Graph-shape rules (type membership, IRI vs literal) live in shapes/v1/CredentialShape.jsonld.",
  "type": "object",
  "required": ["@context", "type", "issuer", "credentialSubject"],
  "properties": {
    "@context": { "$ref": "#/$defs/context" },
    "id": { "type": "string" },
    "type": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" },
      "contains": { "const": "VerifiableCredential" }
    },
    "issuer": { "$ref": "#/$defs/issuer" },
    "issuanceDate": { "type": "string", "format": "date-time" },
    "validFrom": { "type": "string", "format": "date-time" },
    "validUntil": { "type": "string" },
    "expirationDate": { "type": "string" },
    "credentialSubject": {
      "type": "object",
      "required": ["id"],
      "properties": { "id": { "$ref": "#/$defs/did" } }
    },
    "credentialSchema": { "type": ["object", "array"] },
    "credentialStatus": { "type": ["object", "array"] },
    "proof": { "type": ["object", "array"] }
  },
  "$defs": {
    "did": { "type": "string", "pattern": "^did:[a-z0-9]+:.+" },
    "context": { "oneOf": [{ "type": "string" }, { "type": "array", "minItems": 1 }, { "type": "object" }] },
    "issuer": {
      "oneOf": [
        { "$ref": "#/$defs/did" },
        { "type": "object", "required": ["id"], "properties": { "id": { "$ref": "#/$defs/did" } } }
      ]
    }
  }
}
