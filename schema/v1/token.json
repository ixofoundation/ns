{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://w3id.org/ixo/schema/v1/token",
  "title": "IXO Impact Token Metadata",
  "description": "Document-shape schema for impact-token metadata (a plain-JSON linked resource, not JSON-LD). There is no SHACL shape — tokens are not expanded to RDF.",
  "type": "object",
  "required": ["id", "type", "name", "tokenName"],
  "properties": {
    "id": { "type": "string" },
    "type": { "type": "string" },
    "name": { "type": "string", "minLength": 1 },
    "tokenName": { "type": "string", "minLength": 1 },
    "decimals": { "type": "integer", "minimum": 0 },
    "description": { "type": "string" },
    "image": { "type": "string" },
    "properties": {
      "type": "object",
      "properties": {
        "denom": { "type": "string" },
        "icon": { "type": "string" },
        "maxSupply": { "type": ["string", "number"] }
      }
    }
  }
}
