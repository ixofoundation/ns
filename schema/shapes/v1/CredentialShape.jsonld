{
  "@context": {
    "sh": "http://www.w3.org/ns/shacl#",
    "ixo": "https://w3id.org/ixo/vocab/v1#",
    "cred": "https://www.w3.org/2018/credentials#",
    "rdf": "http://www.w3.org/1999/02/22-rdf-syntax-ns#",
    "rdfs": "http://www.w3.org/2000/01/rdf-schema#"
  },
  "@id": "https://w3id.org/ixo/schema/shapes/v1/CredentialShape",
  "@type": "sh:NodeShape",
  "sh:targetClass": { "@id": "ixo:Credential" },
  "sh:nodeKind": { "@id": "sh:IRI" },
  "rdfs:comment": "A verifiable credential: an IRI node typed ixo:Credential with one issuer and at least one credential subject, both identified by IRIs.",
  "sh:property": [
    {
      "sh:path": { "@id": "cred:issuer" },
      "sh:minCount": 1,
      "sh:maxCount": 1,
      "sh:nodeKind": { "@id": "sh:IRI" },
      "sh:name": "issuer"
    },
    {
      "sh:path": { "@id": "cred:credentialSubject" },
      "sh:minCount": 1,
      "sh:nodeKind": { "@id": "sh:IRI" },
      "sh:name": "credentialSubject"
    }
  ]
}
