  "@graph": [
    {
      "@id": "https://w3id.org/ixo/vocab/v1",
      "@type": "owl:Ontology",
      "dcterms:title": {
        "@value": "IXO Core Vocabulary",
        "@language": "en"
      },
      "dcterms:description": {
        "@value": "The core RDFS/OWL vocabulary for the IXO Spatial Web: the classes and properties used to interpret entity domains, claims, credentials and linked resources published on Impact Hub. This vocabulary is the interpretation layer only; specific entity instances live on-chain.",
        "@language": "en"
      },
      "dcterms:creator": {
        "@value": "IXO Foundation"
      },
      "dcterms:license": {
        "@id": "https://opensource.org/licenses/MIT"
      },
      "dcterms:created": {
        "@value": "2026-06-04",
        "@type": "xsd:date"
      },
      "owl:versionInfo": {
        "@value": "1.0.0",
        "@language": "en"
      },
      "owl:versionIRI": {
        "@id": "https://w3id.org/ixo/vocab/v1/1.0.0"
      },
      "vann:preferredNamespacePrefix": "ixo",
      "vann:preferredNamespaceUri": "https://w3id.org/ixo/vocab/v1#"
    },
    {
      "@id": "ixo:Entity",
      "@type": [
        "rdfs:Class",
        "owl:Class"
      ],
      "rdfs:label": {
        "@value": "Entity",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "A self-sovereign digital domain on the IXO Spatial Web, identified by a Decentralised Identifier (DID) and described by an on-chain IID document.",
        "@language": "en"
      }
    },
    {
      "@id": "ixo:Domain",
      "@type": [
        "rdfs:Class",
        "owl:Class"
      ],
      "rdfs:subClassOf": {
        "@id": "ixo:Entity"
      },
      "rdfs:label": {
        "@value": "Domain",
        "@language": "en"
      },
      "rdfs:comment": {
        "@value": "The identity and namespace boundary owned by an entity, under which its resources, claims and relationships are organised and resolved.",
        "@language": "en"
      }
    },
    {
      "@id": "ixo:Project",
