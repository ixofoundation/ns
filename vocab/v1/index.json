        "rdfs:Class",
        "owl:Class"
      ],
      "rdfs:subClassOf": {
        "@id": "ixo:Entity"
      },
      "rdfs:label": {
        "@value": "Project",
        "@language": "en"
      },
      "rdfs:comment": {
